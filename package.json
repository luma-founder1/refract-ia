{
  "name": "refract",
  "version": "0.1.0",
  "description": "Transform AI-generated code into maintainable structure",
  "author": "Refract Team",
  "scripts": {
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "biome format --write ./src",
    "check": "biome check ./src",
    "typecheck": "tsc --noEmit",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
