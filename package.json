    "@xyflow/react": "^12.10.2",
    "better-sqlite3": "^9.4.3",
    "clsx": "^2.1.0",
    "dagre": "^0.8.5",
    "dotenv": "^17.4.2",
    "groq-sdk": "^1.1.2",
    "lucide-react": "^0.363.0",
    "reactflow": "^11.11.4",
    "simple-git": "^3.36.0",
    "tailwind-merge": "^2.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
